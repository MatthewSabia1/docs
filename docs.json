{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AdRecon",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/ad-feed",
              "features/filters",
              "features/saved-ads",
              "features/projects",
              "features/page-ripper"
            ]
          },
          {
            "group": "User Management",
            "pages": [
              "user-management/profile"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.adrecon.io",
          "icon": "rocket"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.adrecon.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign In",
      "href": "https://app.adrecon.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {}
  }
}
